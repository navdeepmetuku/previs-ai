# ── PREVIS-AI .env.local ─────────────────────────────────────────────────────
# Rename this file to .env.local after cloning, then fill in your keys.

# Gemini AI — scene extraction and VISH intelligence
# Get free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# HuggingFace Inference API (optional — may be blocked on some networks)
# Get free key at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_hf_key_here

# fal.ai — FLUX.1-schnell (needs billing top-up at fal.ai/dashboard/billing)
# Get key at: https://fal.ai/dashboard/keys
FAL_KEY=your_fal_key_here

# ── IMAGE GENERATION PROVIDER SWITCH ─────────────────────────────────────────
# Development:   leave REPLICATE_API_TOKEN blank → Pollinations (free, auto)
# Presentation:  uncomment below → Replicate FLUX.1-schnell (high quality)
# Get free token at: https://replicate.com/account/api-tokens
# REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
